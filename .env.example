# ── Discord ─────────────────────────────────────────────────────────────────
# Get your token from: https://discord.com/developers/applications
DISCORD_TOKEN=your_bot_token_here

# ── Neon PostgreSQL ──────────────────────────────────────────────────────────
#
# TWO URLs are required:
#
# 1. DIRECT — used only by sqlx::migrate! at startup.
#    Schema migrations must NOT go through PgBouncer (transaction mode
#    doesn't support DDL statements reliably).
DATABASE_URL=postgresql://USER:PASS@ep-your-endpoint.region.aws.neon.tech/neondb?sslmode=require

# 2. POOLED — used for ALL runtime queries.
#    Add "-pooler" to the endpoint hostname to route through Neon's PgBouncer,
#    which supports up to 10,000 concurrent client connections.
DATABASE_POOL_URL=postgresql://USER:PASS@ep-your-endpoint-pooler.region.aws.neon.tech/neondb?sslmode=require

# ── Pool tuning ──────────────────────────────────────────────────────────────
# How many persistent server connections SQLx holds open to PgBouncer.
# PgBouncer multiplexes thousands of clients over these.
# 10 is correct for Neon — do NOT set this high.
DB_MAX_CONNECTIONS=10

# ── TopStats.gg ──────────────────────────────────────────────────────────────
# API token from topstats.gg — used to display vote counts in /stats.
# Optional: the /stats command works without it, just won't show vote data.
TOPSTATS_TOKEN=

# Discord webhook for service status, deploy notes, and fallback notifications.
STATUS_WEBHOOK_URL=

# Optional dedicated webhook for Top.gg vote reward notifications.
# If this is empty, vote rewards fall back to STATUS_WEBHOOK_URL.
VOTE_WEBHOOK_URL=

# Optional labels used in the startup status webhook.
APP_ENV=production
PUBLIC_API_URL=https://aegisforge-bot.fly.dev

# ── Logging ──────────────────────────────────────────────────────────────────
# Suppresses noisy sqlx query logging in production.
RUST_LOG=aegisforge=info,sqlx=warn

# Set to true before enabling Discord App Directory Discovery.
# This hides gambling-adjacent economy subcommands from global registration.
DISCOVERY_SAFE_COMMANDS=false
